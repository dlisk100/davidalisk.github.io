---
import "@fontsource/inter/400.css";
import "@fontsource/inter/500.css";
import "@fontsource/inter/600.css";
import "@fontsource/source-serif-4/600.css";
import "../styles/globals.css";
import FilmAtlasExperience from "../components/film-atlas/FilmAtlasExperience.astro";

const dataBase = "/film-atlas/data";

const title = "The Film Atlas";
const description =
  "An interactive map of 10,000 films arranged by experiential similarity: story, mood, texture, theme, and audience perception.";
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="description" content={description} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content="website" />
    <meta property="og:url" content={Astro.url} />
    <meta property="og:image" content={new URL("/og-default.png", Astro.url)} />
    <meta name="twitter:card" content="summary_large_image" />
    <title>{title}</title>
  </head>
  <body>
    <FilmAtlasExperience dataBase={dataBase} />
  </body>
</html>

<style is:global>
  :root {
    color-scheme: dark;
  }

  html,
  body {
    margin: 0;
    min-height: 100%;
    background: #050505;
  }

  body {
    font-family: Inter, ui-sans-serif, system-ui;
  }
</style>
